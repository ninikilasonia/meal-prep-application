# Base URL the frontend uses for backend calls.
#
# Local development (default): use "/api" so calls go through the Vite dev
# proxy (see vite.config.js) and avoid browser CORS. The proxy forwards
# "/api/*" to the FastAPI backend at http://localhost:8000.
VITE_API_BASE_URL=/api

# If the backend enables CORS, you can instead point directly at it:
# VITE_API_BASE_URL=http://localhost:8000
